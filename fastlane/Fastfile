default_platform(:ios)

APP_ID  = "com.zubeid.hadithreader"
SCHEME  = "HadithReader"
PROJECT = "HadithReader.xcodeproj"

def asc_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV["ASC_KEY_PATH"],
    key_content: ENV["ASC_KEY_CONTENT"],
    is_key_content_base64: true
  )
end

platform :ios do
  desc "Build Hadith Reader and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]
    key = asc_key
    sh("cd .. && xcodegen generate")
    if ENV["MATCH_GIT_URL"]
      match(type: "appstore", app_identifier: APP_ID,
            git_url: ENV.fetch("MATCH_GIT_URL"), readonly: true, api_key: key)
    end
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")
    xcargs = "CURRENT_PROJECT_VERSION=#{build_number}"
    if (team = ENV["DEVELOPMENT_TEAM"])
      xcargs += " DEVELOPMENT_TEAM=#{team} -allowProvisioningUpdates"
    end
    build_app(project: PROJECT, scheme: SCHEME, export_method: "app-store",
              xcargs: xcargs, output_directory: "build", clean: true)
    upload_to_testflight(api_key: key, skip_waiting_for_build_processing: true)
  end
end
